# Database files
data/*.db
*.db-wal
*.db-shm

# Uploaded CSVs saved by the server (may contain real bank data)
data/inbox/*
!data/inbox/.gitkeep

# Node modules
node_modules/
web/node_modules/
web/dist/
web/*.tsbuildinfo
web/vite.config.js
web/vite.config.d.ts

# Session logs (keep the directory)
memory/session_logs/*
!memory/session_logs/.gitkeep

# Learned/runtime memory state — real data from interactive use, not fixtures.
# Code falls back to {}/[] when these are missing (policy.ts, rules.ts).
memory/anomaly_log.json
memory/vendor_rules.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code local session/config directory
.claude/
