{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["test/**/*.ts", "server/**/*.ts", ".pi/extensions/**/*.ts"]
}
